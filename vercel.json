{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "experimentalServices": {
    "frontend": {
      "entrypoint": "apps/web",
      "framework": "nextjs",
      "routePrefix": "/"
    },
    "backend": {
      "entrypoint": "app.py",
      "buildCommand": "PLAYWRIGHT_BROWSERS_PATH=.playwright-browsers python -m playwright install chromium",
      "routePrefix": "/api/python"
    }
  },
  "crons": [
    {
      "path": "/api/cron/daily-solve",
      "schedule": "5 0 * * *"
    }
  ]
}
